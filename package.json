{
  "name": "@gesslar/mediawiki-mcp",
  "version": "0.1.0",
  "description": "MCP server for Integrating with MediaWiki",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "mediawiki-mcp": "./src/index.js"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "types:build": "tsc -p tsconfig.types.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "submit": "npm publish --access public",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit --publish --restack --ai -m",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/mediawiki-mcp.git"
  },
  "keywords": [
    "wiki",
    "mediawiki",
    "mcp",
    "model-context-protocol",
    "janet",
    "jackson",
    "was",
    "played"
  ],
  "author": "gesslar",
  "license": "0BSD",
  "homepage": "https://github.com/gesslar/mediawiki-mcp#readme",
  "dependencies": {
    "@gesslar/wikid": "^2.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.0",
    "eslint": "^10.2.0"
  }
}
